# ── Hetzner Cloud (required) ─────────────────────────────────
HCLOUD_TOKEN=your_hetzner_api_token_here

# ── VM Configuration (optional) ──────────────────────────────
# SERVER_NAME is a prefix — actual server name will be <prefix>-<6 random hex chars>
SERVER_NAME=hardened-node
SERVER_TYPE=cx22
LOCATION=fsn1
OS_IMAGE=ubuntu-24.04

# ── User (optional — random if blank) ────────────────────────
# Generated name format: svc_<8 hex chars>
NEW_USER_NAME=

# ── Email alerts via msmtp (optional) ────────────────────────
# If set, Phase 2 installs msmtp and wires it as the system MTA
# so logwatch, auditd, AIDE, and rkhunter can send reports.
# Requires an existing external SMTP relay with TLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL=
